generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  username      String   @unique
  password      String
  image         String?
  pin           String?
  locale        String   @default("id")
  currency      String   @default("IDR")
  plan          String   @default("basic")
  role          String   @default("user")
  status        String   @default("active")
  subscriptionEnd DateTime?
  maxCategories  Int      @default(10)
  maxSavings     Int      @default(3)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  transactions  Transaction[]
  categories    Category[]
  savingsTargets SavingsTarget[]
  allocations   Allocation[]
  inviteTokens  InviteToken[]
  budgets       Budget[]
  notifications Notification[]
  businesses    Business[]
}

model Category {
  id            String       @id @default(cuid())
  name          String
  type          String
  color         String?
  icon          String?
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  budgets       Budget[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([name, userId, type])
  @@index([userId, type])
}

model Transaction {
  id          String       @id @default(cuid())
  type        String
  amount      Float
  description String?
  categoryId  String
  category    Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime     @default(now())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  allocation  Allocation?

  @@index([userId, date])
  @@index([userId, type])
}

model SavingsTarget {
  id           String      @id @default(cuid())
  name         String
  targetAmount Float
  currentAmount Float      @default(0)
  targetDate   DateTime
  initialInvestment Float  @default(0)
  monthlyContribution Float
  allocationPercentage Float @default(0)
  isAllocated  Boolean     @default(false)
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  allocations  Allocation[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([userId])
}

model Allocation {
  id              String        @id @default(cuid())
  transactionId   String        @unique
  transaction     Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  targetId        String
  target          SavingsTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount          Float
  percentage      Float
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([targetId, createdAt])
  @@index([userId])
}

model InviteToken {
  id          String   @id @default(cuid())
  token       String   @unique
  createdBy   String
  creator     User     @relation(fields: [createdBy], references: [id])
  email       String?
  plan        String   @default("basic")
  maxUses     Int      @default(1)
  usedCount   Int      @default(0)
  expiresAt   DateTime?
  usedBy      String?
  isUsed      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([token])
  @@index([createdBy])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("info")
  isActive  Boolean  @default(true)
  priority  Int      @default(0)
  startsAt  DateTime?
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, priority])
  @@index([type])
}

model AdminActivityLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  target    String?
  details   String?
  createdAt DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([action])
  @@index([createdAt])
}

model Budget {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  amount      Float
  month       Int      // 1-12
  year        Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, categoryId, month, year])
  @@index([userId, month, year])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  title       String
  message     String
  amount      Float?
  isRead      Boolean  @default(false)
  actionUrl   String?
  createdAt   DateTime @default(now())

  @@index([userId, isRead, createdAt])
  @@index([userId, type])
  @@index([createdAt])
}

model PlatformConfig {
  id                   String   @id @default("platform")
  defaultPlan          String   @default("basic")
  defaultMaxCategories Int      @default(10)
  defaultMaxSavings    Int      @default(3)
  autoSuspendExpired   Boolean  @default(true)
  basicPlanFeatures    String?
  proPlanFeatures      String?
  basicPlanPrice       String?  @default("Gratis")
  proPlanPrice         String?  @default("Rp 99.000")
  basicPlanDiscount    String?
  proPlanDiscount      String?
  basicPlanDiscountLabel String?
  proPlanDiscountLabel String?
  basicPurchaseUrl     String?
  proPurchaseUrl       String?
  trialEnabled         Boolean  @default(true)
  trialDurationDays    Int      @default(30)
  trialPlan            String?  @default("basic")
  whatsappNumber       String?
  registrationOpen     Boolean  @default(true)
  registrationMessage  String?
  availablePlans       String?  @default("[\"basic\",\"pro\",\"ultimate\"]")
  sectionVisibility    String?
  exportEnabled        String?
  updatedAt            DateTime @updatedAt
}

// ============================================
// BUSINESS MODULE
// ============================================

model Business {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  category      String   // "bisnis" or "investasi"
  description   String?
  address       String?
  phone         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Business relations
  customers        BusinessCustomer[]
  invoices         BusinessInvoice[]
  sales            BusinessSale[]
  cashEntries      BusinessCash[]
  debts            BusinessDebt[]
  incomeAllocs     BusinessIncomeAllocation[]
  portfolios       InvestmentPortfolio[]
  watchlist        WatchlistItem[]
  invoiceSettings  InvoiceSettings?
  products         Product[]

  @@index([userId, category])
  @@index([userId])
}

model BusinessCustomer {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name        String
  email       String?
  phone       String?
  address     String?
  notes       String?
  invoices    BusinessInvoice[]
  sales       BusinessSale[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId])
}

model BusinessInvoice {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId    String?
  customer      BusinessCustomer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  invoiceNumber String
  date          DateTime @default(now())
  dueDate       DateTime?
  items         String   // JSON: [{description, qty, price, total}]
  subtotal      Float
  tax           Float    @default(0)
  discount      Float    @default(0)
  total         Float
  status        String   @default("pending") // pending, paid, cancelled, overdue
  notes         String?
  pdfUrl        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([businessId, date])
  @@index([businessId, status])
}

model BusinessSale {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId    String?
  customer      BusinessCustomer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  invoiceId     String?
  description   String
  amount        Float
  date          DateTime @default(now())
  paymentMethod String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([businessId, date])
}

model BusinessCash {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  type        String   // "kas_besar", "kas_kecil", "kas_keluar"
  amount      Float
  description String
  category    String?  // e.g. "modal", "operasional", "gaji", etc.
  date        DateTime @default(now())
  referenceId String?  // optional link to sale/invoice
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId, type, date])
  @@index([businessId, date])
}

model BusinessDebt {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  type          String   // "hutang" (payable) or "piutang" (receivable)
  counterpart   String   // name of the person/company
  amount        Float
  remaining     Float
  dueDate       DateTime?
  description   String?
  status        String   @default("active") // active, partially_paid, paid, overdue
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([businessId, type])
  @@index([businessId, status])
  @@index([businessId, dueDate])
}

model BusinessIncomeAllocation {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  saleId        String?
  amount        Float
  percentage    Float
  allocatedAt   DateTime @default(now())
  personalNote  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([businessId])
}

model Product {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  sku           String?  @unique
  price         Float
  stock         Int      @default(0)
  category      String?
  unit          String?  @default("pcs")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([businessId])
}

// ============================================
// INVESTMENT MODULE
// ============================================

model InvestmentPortfolio {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  type          String   // "saham", "crypto", "forex"
  symbol        String
  name          String?
  entryPrice    Float
  currentPrice  Float    @default(0)
  quantity      Float
  targetPrice   Float?
  stopLoss      Float?
  status        String   @default("open") // open, closed
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  journals      TradingJournal[]

  @@index([businessId, type])
  @@index([businessId, status])
}

model TradingJournal {
  id            String   @id @default(cuid())
  portfolioId   String
  portfolio     InvestmentPortfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  type          String   // "buy", "sell"
  entryPrice    Float
  exitPrice     Float?
  quantity      Float
  pnl           Float    @default(0)
  pnlPercentage Float    @default(0)
  riskReward    Float?
  fees          Float    @default(0)
  notes         String?
  date          DateTime @default(now())
  closedAt      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([portfolioId, date])
}

model WatchlistItem {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  symbol      String
  type        String
  name        String?
  targetBuy   Float?
  targetSell  Float?
  alertOnSignal Boolean @default(true)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId])
  @@unique([businessId, symbol, type])
}

// ============================================
// INVOICE SETTINGS MODULE
// ============================================

model InvoiceSettings {
  id            String   @id @default(cuid())
  businessId    String   @unique
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  // Template & Design
  template      String   @default("modern")   // "modern", "classic", "minimal"
  primaryColor  String   @default("#1E293B")  // hex color for header/accent
  secondaryColor String  @default("#BB86FC")  // hex color for accents
  // Branding
  logoUrl       String?                      // business logo (base64 or URL)
  signatureUrl  String?                      // signature image (base64)
  businessName  String?                      // display name on invoice
  businessAddress String?                    // address on invoice
  businessPhone   String?                    // phone on invoice
  businessEmail   String?                    // email on invoice
  businessWebsite String?                    // website on invoice
  // Footer
  footerText    String?                      // custom footer text
  termsText     String?                      // payment terms
  bankName      String?                      // bank name for payment info
  bankAccount   String?                      // bank account number
  bankHolder    String?                      // account holder name
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
