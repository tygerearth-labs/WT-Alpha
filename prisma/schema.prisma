generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  username      String   @unique
  password      String
  image         String?
  pin           String?
  locale        String   @default("id")
  currency      String   @default("IDR")
  plan          String   @default("basic")
  role          String   @default("user")
  status        String   @default("active")
  subscriptionEnd DateTime?
  maxCategories  Int      @default(10)
  maxSavings     Int      @default(3)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  transactions  Transaction[]
  categories    Category[]
  savingsTargets SavingsTarget[]
  allocations   Allocation[]
  inviteTokens  InviteToken[]
  budgets       Budget[]
  notifications Notification[]
}

model Category {
  id            String       @id @default(cuid())
  name          String
  type          String
  color         String?
  icon          String?
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  budgets       Budget[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([name, userId, type])
  @@index([userId, type])
}

model Transaction {
  id          String       @id @default(cuid())
  type        String
  amount      Float
  description String?
  categoryId  String
  category    Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime     @default(now())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  allocation  Allocation?

  @@index([userId, date])
  @@index([userId, type])
}

model SavingsTarget {
  id           String      @id @default(cuid())
  name         String
  targetAmount Float
  currentAmount Float      @default(0)
  targetDate   DateTime
  initialInvestment Float  @default(0)
  monthlyContribution Float
  allocationPercentage Float @default(0)
  isAllocated  Boolean     @default(false)
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  allocations  Allocation[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([userId])
}

model Allocation {
  id              String        @id @default(cuid())
  transactionId   String        @unique
  transaction     Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  targetId        String
  target          SavingsTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount          Float
  percentage      Float
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([targetId, createdAt])
  @@index([userId])
}

model InviteToken {
  id          String   @id @default(cuid())
  token       String   @unique
  createdBy   String
  creator     User     @relation(fields: [createdBy], references: [id])
  email       String?
  plan        String   @default("basic")
  maxUses     Int      @default(1)
  usedCount   Int      @default(0)
  expiresAt   DateTime?
  usedBy      String?
  isUsed      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([token])
  @@index([createdBy])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("info")
  isActive  Boolean  @default(true)
  priority  Int      @default(0)
  startsAt  DateTime?
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, priority])
  @@index([type])
}

model AdminActivityLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  target    String?
  details   String?
  createdAt DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([action])
  @@index([createdAt])
}

model Budget {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  amount      Float
  month       Int      // 1-12
  year        Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, categoryId, month, year])
  @@index([userId, month, year])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // income, expense, savings, system, broadcast, subscription, upgrade
  title       String
  message     String
  amount      Float?
  isRead      Boolean  @default(false)
  actionUrl   String?  // Optional URL to navigate to when clicked
  createdAt   DateTime @default(now())

  @@index([userId, isRead, createdAt])
  @@index([userId, type])
  @@index([createdAt])
}

model PlatformConfig {
  id                   String   @id @default("platform")
  defaultPlan          String   @default("basic")
  defaultMaxCategories Int      @default(10)
  defaultMaxSavings    Int      @default(3)
  autoSuspendExpired   Boolean  @default(true)
  basicPlanFeatures    String?  // JSON array of feature strings
  proPlanFeatures      String?  // JSON array of feature strings
  basicPlanPrice       String?  @default("Gratis")
  proPlanPrice         String?  @default("Rp 99.000")
  basicPlanDiscount    String?  // e.g. "20%" or "Rp 20.000"
  proPlanDiscount      String?  // e.g. "30%" or "Rp 30.000"
  basicPlanDiscountLabel String? // e.g. "Diskon Early Bird"
  proPlanDiscountLabel String?  // e.g. "Diskon Launching"
  basicPurchaseUrl     String?  // External purchase link for basic plan
  proPurchaseUrl       String?  // External purchase link for pro plan
  trialEnabled         Boolean  @default(true)
  trialDurationDays    Int      @default(30)
  trialPlan            String?  @default("basic")
  whatsappNumber       String?  // WhatsApp number for registration contact
  registrationOpen     Boolean  @default(true)
  registrationMessage  String?  // Custom message when registration is closed
  availablePlans       String?  @default("[\"basic\",\"pro\"]") // JSON array of available plan names
  sectionVisibility    String?  // JSON object: { "basic": { "budget": true, "healthScore": true, ... }, "pro": { ... } }
  exportEnabled        String?  // JSON object: { "basic": { "pdf": true, "excel": false }, "pro": { "pdf": true, "excel": true } }
  updatedAt            DateTime @updatedAt
}
