generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  username      String   @unique
  password      String
  image         String?
  pin           String?
  locale        String   @default("id")
  currency      String   @default("IDR")
  plan          String   @default("basic")
  role          String   @default("user")
  status        String   @default("active")
  subscriptionEnd DateTime?
  maxCategories  Int      @default(10)
  maxSavings     Int      @default(3)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  transactions  Transaction[]
  categories    Category[]
  savingsTargets SavingsTarget[]
  allocations   Allocation[]
  inviteTokens  InviteToken[]
  budgets       Budget[]
  notifications  Notification[]
  businesses     Business[]
  billReminders  BillReminder[]
}

model Category {
  id            String       @id @default(cuid())
  name          String
  type          String
  color         String?
  icon          String?
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  budgets       Budget[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([name, userId, type])
  @@index([userId, type])
}

model Transaction {
  id          String       @id @default(cuid())
  type        String
  amount      Float
  description String?
  categoryId  String
  category    Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime     @default(now())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  allocation  Allocation?

  @@index([userId, date])
  @@index([userId, type])
}

model SavingsTarget {
  id           String      @id @default(cuid())
  name         String
  targetAmount Float
  currentAmount Float      @default(0)
  targetDate   DateTime
  initialInvestment Float  @default(0)
  monthlyContribution Float
  allocationPercentage Float @default(0)
  isAllocated  Boolean     @default(false)
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  allocations  Allocation[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([userId])
}

model Allocation {
  id              String        @id @default(cuid())
  transactionId   String        @unique
  transaction     Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  targetId        String
  target          SavingsTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount          Float
  percentage      Float
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([targetId, createdAt])
  @@index([userId])
}

model InviteToken {
  id          String   @id @default(cuid())
  token       String   @unique
  createdBy   String
  creator     User     @relation(fields: [createdBy], references: [id])
  email       String?
  plan        String   @default("basic")
  maxUses     Int      @default(1)
  usedCount   Int      @default(0)
  expiresAt   DateTime?
  usedBy      String?
  isUsed      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([token])
  @@index([createdBy])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("info")
  isActive  Boolean  @default(true)
  priority  Int      @default(0)
  startsAt  DateTime?
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, priority])
  @@index([type])
}

model AdminActivityLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  target    String?
  details   String?
  createdAt DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([action])
  @@index([createdAt])
}

model Budget {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  amount      Float
  month       Int      // 1-12
  year        Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, categoryId, month, year])
  @@index([userId, month, year])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  title       String
  message     String
  amount      Float?
  isRead      Boolean  @default(false)
  actionUrl   String?
  createdAt   DateTime @default(now())

  @@index([userId, isRead, createdAt])
  @@index([userId, type])
  @@index([createdAt])
}

model PlatformConfig {
  id                   String   @id @default("platform")
  defaultPlan          String   @default("basic")
  defaultMaxCategories Int      @default(10)
  defaultMaxSavings    Int      @default(3)
  autoSuspendExpired   Boolean  @default(true)
  basicPlanFeatures    String?
  proPlanFeatures      String?
  basicPlanPrice       String?  @default("Gratis")
  proPlanPrice         String?  @default("Rp 99.000")
  basicPlanDiscount    String?
  proPlanDiscount      String?
  basicPlanDiscountLabel String?
  proPlanDiscountLabel String?
  basicPurchaseUrl     String?
  proPurchaseUrl       String?
  ultimatePlanPrice       String?  @default("Rp 199.000")
  ultimatePlanFeatures    String?
  ultimatePlanDiscount    String?
  ultimatePlanDiscountLabel String?
  ultimatePurchaseUrl     String?
  trialEnabled         Boolean  @default(true)
  trialDurationDays    Int      @default(30)
  trialPlan            String?  @default("basic")
  whatsappNumber       String?
  registrationOpen     Boolean  @default(true)
  registrationMessage  String?
  availablePlans       String?  @default("[\"basic\",\"pro\",\"ultimate\"]")
  sectionVisibility    String?
  exportEnabled        String?
  emailNotifications   String?
  landingPageConfig    String?
  landingPageStats     String?
  updatedAt            DateTime @updatedAt
}

// ============================================
// BUSINESS MODULE
// ============================================

model Business {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  category      String   // "bisnis" or "investasi"
  description   String?
  address       String?
  phone         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Business relations
  customers        BusinessCustomer[]
  invoices         BusinessInvoice[]
  sales            BusinessSale[]
  cashEntries      BusinessCash[]
  debts            BusinessDebt[]
  incomeAllocs     BusinessIncomeAllocation[]
  categories       BusinessCategory[]
  investors        BusinessInvestor[]
  portfolios       InvestmentPortfolio[]
  watchlist        WatchlistItem[]
  bankAccounts     BusinessBankAccount[]
  debtPayments     BusinessDebtPayment[]
  invoiceSettings  InvoiceSettings?
  products         Product[]
  budgets          BusinessBudget[]
  fundAllocations  BusinessFundAllocation[]

  @@index([userId, category])
  @@index([userId])
}

model BusinessCustomer {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name        String
  email       String?
  phone       String?
  address     String?
  notes       String?
  invoices    BusinessInvoice[]
  sales       BusinessSale[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId])
}

model BusinessInvoice {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId    String?
  customer      BusinessCustomer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  invoiceNumber String
  date          DateTime @default(now())
  dueDate       DateTime?
  items         String   // JSON: [{description, qty, price, total}]
  subtotal      Float
  tax           Float    @default(0)
  discount      Float    @default(0)
  total         Float
  paidAmount    Float    @default(0)
  status        String   @default("pending") // pending, paid, cancelled, overdue
  notes         String?
  pdfUrl        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([businessId, date])
  @@index([businessId, status])
}

model BusinessSale {
  id               String   @id @default(cuid())
  businessId       String
  business         Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId       String?
  customer         BusinessCustomer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  invoiceId        String?
  description      String
  amount           Float
  date             DateTime @default(now())
  paymentMethod    String?
  notes            String?
  downPayment      Float?
  // DP amount
  downPaymentPct   Float?
  // DP percentage
  installmentTempo Int?
  // Number of installments (months)
  installmentAmount Float?
  // Monthly installment amount
  investorSharePct Float?   @default(0)
  // Percentage for investor profit sharing
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([businessId, date])
}

model BusinessCash {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  type        String   // "kas_besar", "kas_kecil", "kas_keluar", "investor"
  amount      Float
  description String
  category    String?  // e.g. "modal", "operasional", "gaji", "investor_modal", etc.
  date        DateTime @default(now())
  referenceId String?  // optional link to sale/invoice/investor
  source      String?  // where money came from / deducted from: "kas_besar", "kas_kecil", "investor"
  investorId  String?
  investor    BusinessInvestor? @relation(fields: [investorId], references: [id], onDelete: SetNull)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId, type, date])
  @@index([businessId, date])
  @@index([investorId])
}

model BusinessCategory {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  type        String   // "pemasukan", "pengeluaran", "produk"
  name        String
  color       String?  @default("#03DAC6")
  icon        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([businessId, type, name])
  @@index([businessId, type])
}

model BusinessInvestor {
  id                 String   @id @default(cuid())
  businessId         String
  business           Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name               String
  phone              String?
  email              String?
  address            String?
  notes              String?
  totalInvestment    Float    @default(0)
  profitSharePct     Float    @default(0)
  // Percentage of sales profit for this investor
  status             String   @default("active") // active, inactive
  joinDate           DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now())
  cashEntries        BusinessCash[]
  fundAllocations    BusinessFundAllocation[]

  @@index([businessId, status])
}

model BusinessDebt {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  type          String   // "hutang" (payable) or "piutang" (receivable)
  counterpart   String   // name of the person/company
  amount        Float
  remaining     Float
  dueDate       DateTime?
  description   String?
  status        String   @default("active") // active, partially_paid, paid, overdue
  downPayment       Float?    // DP amount (if different from remaining)
  installmentAmount Float?    // Fixed monthly installment amount
  installmentPeriod Int?      // Number of installments (months)
  nextInstallmentDate DateTime? // Next installment due date
  referenceId   String?  // optional link to sale/invoice that created this debt
  payments      BusinessDebtPayment[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([businessId, type])
  @@index([businessId, status])
  @@index([businessId, dueDate])
}

model BusinessIncomeAllocation {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  saleId        String?
  targetType    String   @default("business")   // "business", "personal_cash_in", "savings_target"
  targetId      String?                           // savingsTarget id when targetType = "savings_target"
  amount        Float
  percentage    Float
  allocatedAt   DateTime @default(now())
  personalNote  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([businessId])
}

model Product {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  sku           String?  @unique
  price         Float
  stock         Int      @default(0)
  category      String?
  unit          String?  @default("pcs")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([businessId])
}

// ============================================
// INVESTMENT MODULE
// ============================================

model InvestmentPortfolio {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  type          String   // "saham", "crypto", "forex", "crypto_perpetual"
  symbol        String
  name          String?
  entryPrice    Float
  currentPrice  Float    @default(0)
  quantity      Float
  targetPrice   Float?
  stopLoss      Float?
  status        String   @default("open") // open, closed
  notes         String?
  currency      String   @default("IDR")
  leverage      Float?   // for forex/crypto_perpetual
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  journals      TradingJournal[]

  @@index([businessId, type])
  @@index([businessId, status])
}

model TradingJournal {
  id              String   @id @default(cuid())
  portfolioId     String
  portfolio       InvestmentPortfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  type            String   // "buy", "sell"
  entryPrice      Float
  exitPrice       Float?
  quantity        Float
  pnl             Float    @default(0)
  pnlPercentage   Float    @default(0)
  riskReward      Float?
  fees            Float    @default(0)
  notes           String?
  date            DateTime @default(now())
  closedAt        DateTime?

  // ── Trading Journal Core Fields ──
  strategy        String?  // Breakout, Mean Reversion, FVG, Scalping, Swing, etc.
  emotionalState  String?  // Calm, Revenge Trading, FOMO, Confident, Anxious, Disciplined
  confluence      String?  // JSON array: ["RSI Divergence", "Support Level", "Volume Spike"]
  screenshotBefore String? // image URL or base64
  screenshotAfter  String? // image URL or base64

  // ── Instrument-Specific Fields ──
  instrumentCategory String? // "saham", "forex", "crypto_perpetual"
  lotSize         Float?   // forex lot size
  pipValue        Float?   // forex pip value per standard lot
  leverage        Float?   // crypto_perpetual / forex leverage
  fundingFee      Float?   // crypto_perpetual funding fee
  liquidationPrice Float?  // crypto_perpetual estimated liquidation price

  // ── Multi-Currency Fields ──
  tradeCurrency   String?  // currency of the trade (USD, IDR, EUR, etc.)
  exchangeRate    Float?   // rate at time of trade close (to base currency)
  riskMultiple    Float?   // R-multiple: profit / initial risk

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([portfolioId, date])
}

model ExchangeRate {
  id            String   @id @default(cuid())
  fromCurrency  String   // "USD", "IDR", "EUR", etc.
  toCurrency    String   // "USD", "IDR", "EUR", etc.
  rate          Float
  source        String   @default("manual") // "manual", "api", "auto"
  date          DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([fromCurrency, toCurrency, date])
}

model WatchlistItem {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  symbol      String
  type        String
  name        String?
  targetBuy   Float?
  targetSell  Float?
  alertOnSignal Boolean @default(true)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId])
  @@unique([businessId, symbol, type])
}

// ============================================
// INVOICE SETTINGS MODULE
// ============================================

model InvoiceSettings {
  id            String   @id @default(cuid())
  businessId    String   @unique
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  // Template & Design
  template      String   @default("modern")   // "modern", "classic", "minimal"
  primaryColor  String   @default("#1E293B")  // hex color for header/accent
  secondaryColor String  @default("#BB86FC")  // hex color for accents
  // Branding
  logoUrl       String?                      // business logo (base64 or URL)
  signatureUrl  String?                      // signature image (base64)
  businessName  String?                      // display name on invoice
  businessAddress String?                    // address on invoice
  businessPhone   String?                    // phone on invoice
  businessEmail   String?                    // email on invoice
  businessWebsite String?                    // website on invoice
  // Footer
  footerText    String?                      // custom footer text
  termsText     String?                      // payment terms
  bankName      String?                      // bank name for payment info
  bankAccount   String?                      // bank account number
  bankHolder    String?                      // account holder name
  darkMode      Boolean  @default(true)       // dark/light theme for PDF
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============================================
// BANK ACCOUNTS (multi-account support)
// ============================================

model BusinessBankAccount {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  bankName      String   // e.g. "BCA", "Mandiri", "BRI"
  accountNumber String
  accountHolder String
  isDefault     Boolean  @default(false)
  displayOrder  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([businessId])
}

// ============================================
// DEBT PAYMENT TRACKING
// ============================================

model BusinessDebtPayment {
  id            String   @id @default(cuid())
  debtId        String
  debt          BusinessDebt @relation(fields: [debtId], references: [id], onDelete: Cascade)
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  amount        Float
  paymentDate   DateTime @default(now())
  paymentMethod String?  // "transfer", "cash", "qris"
  notes         String?
  createdAt     DateTime @default(now())

  @@index([debtId])
  @@index([businessId])
}

// ============================================
// BUSINESS BUDGET MODULE
// ============================================

model BusinessBudget {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  categoryName  String   // expense category name
  categoryId    String?  // optional link to BusinessCategory
  amount        Float    // budget limit for the month
  period        Int      // month (1-12)
  year          Int      // year (2025, etc.)
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  allocations   BusinessFundAllocation[]

  @@unique([businessId, categoryName, period, year])
  @@index([businessId, period, year])
}

model BusinessFundAllocation {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  budgetId      String
  budget        BusinessBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  fundSource    String   // "kas_besar", "kas_kecil", "investor"
  investorId    String?
  investor      BusinessInvestor? @relation(fields: [investorId], references: [id], onDelete: SetNull)
  amount        Float    // allocated amount from this source
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([businessId, budgetId])
  @@index([fundSource])
}

// ============================================
// PERSONAL FINANCE — BILL REMINDERS
// ============================================

model BillReminder {
  id          String   @id @default(cuid())
  userId      String
  name        String
  amount      Float
  dueDate     DateTime
  category    String   @default("Lainnya")
  recurrence  String   @default("one-time") // monthly, weekly, one-time
  isPaid      Boolean  @default(false)
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dueDate])
  @@index([userId, isPaid])
}